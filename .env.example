# ============================
# Master Notepad — Environment
# Скопируйте в .env и заполните
# ============================

# --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/master_notepad

# --- Backend (port 3355) ---
PORT=3355
NODE_ENV=development
CORS_ORIGIN=http://localhost:3356
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# --- Email (опционально) ---
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# --- Telegram (опционально) ---
# TELEGRAM_BOT_TOKEN=

# --- AI Assistant (порт 3002) ---
# Переменные ассистента — в assistant/.env (см. assistant/.env.example)
AI_SERVICE_URL=http://localhost:3002