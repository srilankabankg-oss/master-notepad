# ============================
# Master Notepad — AI Assistant
# Скопируйте в assistant/.env и заполните
# ============================

# --- PostgreSQL (та же БД, что у бэкенда) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/master_notepad

# --- Бэкенд API (для реиндексации) ---
MAIN_API_URL=http://localhost:3355

# --- LLM ---
# Если llm_api_key не задан — AI работает в режиме выдачи сырых результатов поиска
LLM_API_URL=https://api.stepfun.com/step_plan/v1
LLM_API_KEY=
LLM_MODEL=step-3.5-flash

# --- Embedding ---
# EMBEDDING_MODEL=intfloat/multilingual-e5-base

# --- Server ---
PORT=3002
LOG_LEVEL=info