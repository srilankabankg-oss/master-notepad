    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.0",
    "puppeteer": "^25.0.4",
